# ============================================================================
# Genesys Knowledge Fabric File Sync Manager — environment configuration
# ----------------------------------------------------------------------------
# Copy to `.env.local` for local development. NEVER commit real secrets.
# In production, set these in the Vercel Project → Settings → Environment
# Variables UI. Secret values are referenced ONLY server-side and are never
# returned to the browser, logged, or persisted to localStorage.
# ============================================================================

# ============================================================================
# REQUIRED — the app will not run correctly without all of these
# ============================================================================

# Genesys OAuth (server-side Client Credentials). Create an OAuth client of
# grant type "Client Credentials" and assign least-privilege Knowledge permissions.
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
# Region API host WITHOUT scheme (Frankfurt / EU: api.mypurecloud.de).
GENESYS_REGION_API_HOST=api.mypurecloud.de

# Single-administrator login — enforced on every page and API route.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# 32+ char random secret for session cookie, CSRF, and upload-callback tokens.
# Generate with:  openssl rand -base64 48
APP_SESSION_SECRET=

# CSP connect-src allowlist for direct browser→Genesys file uploads. Space-separated
# HTTPS origins for your region's upload host(s). Frankfurt/EU often also needs
# https://*.s3.eu-central-1.amazonaws.com — verify via DevTools on a test upload.
GENESYS_UPLOAD_CONNECT_SRC=https://*.s3.amazonaws.com https://*.pure.cloud

# ============================================================================
# OPTIONAL — sensible defaults apply when unset
# ============================================================================

# Minutes before an idle session expires and re-login is required.
SESSION_TTL_MINUTES=720

# ---- Build / environment metadata (public, non-secret) ----
NEXT_PUBLIC_APP_VERSION=1.2.0
# One of: local | preview | production — shown as an environment banner.
NEXT_PUBLIC_ENVIRONMENT_LABEL=local

# ---- Feature flags (least-privilege; default production posture) ----
ENABLE_SOURCE_DISCOVERY=true
ENABLE_SOURCE_HISTORY=true
ENABLE_SOURCE_CREATION=true
ENABLE_ORG_SYNC_DIAGNOSTICS=false
ENABLE_FULL_SYNC=false
ENABLE_PROXY_UPLOAD=false
ENABLE_SOURCE_UPDATE=false
ENABLE_SOURCE_DELETE=false

# ---- Upload / workflow limits ----
MAX_FILE_WARN_MB=50
MAX_SELECTED_FILES=500
PROXY_UPLOAD_MAX_BYTES=26214400
WORKFLOW_UPLOAD_WAIT_SECONDS=900
