# ============================================================================
# Genesys Knowledge Fabric File Sync Manager — environment configuration
# ----------------------------------------------------------------------------
# Copy to `.env.local` for local development. NEVER commit real secrets.
# In production, set these in the Vercel Project → Settings → Environment
# Variables UI. Secret values are referenced ONLY server-side and are never
# returned to the browser, logged, or persisted to localStorage.
# ============================================================================

# ---- Genesys OAuth (server-side Client Credentials) — REQUIRED ----
# Create an OAuth client of grant type "Client Credentials" in Genesys Cloud
# and assign the least-privilege Knowledge permissions for the features you
# enable (see docs/genesys-setup.md).
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
# Region API host WITHOUT scheme, e.g. api.mypurecloud.com, api.mypurecloud.ie,
# api.usw2.pure.cloud, api.mypurecloud.com.au … (see docs/genesys-setup.md).
GENESYS_REGION_API_HOST=api.mypurecloud.com

# ---- App access control — REQUIRED ----
# The app enforces a single-administrator login on EVERY page and API route.
# No feature is reachable without authenticating as this one user. (Vercel
# Deployment Protection / SSO MAY be layered on top for defense-in-depth, but
# the app's own login is always enforced.)
#
# The sole allowed user's credentials:
ADMIN_USERNAME=admin
# Use a long, high-entropy password. Generate one with:  openssl rand -base64 24
ADMIN_PASSWORD=
# Required: 32+ char random secret used to sign the session cookie, CSRF token,
# and the workflow upload-callback tokens.  openssl rand -base64 48
APP_SESSION_SECRET=
# Optional: minutes before an idle session expires and re-login is required.
SESSION_TTL_MINUTES=720

# ---- Build / environment metadata (public, non-secret) ----
NEXT_PUBLIC_APP_VERSION=1.2.0
# One of: local | preview | production — shown as an environment banner.
NEXT_PUBLIC_ENVIRONMENT_LABEL=local

# ---- Feature flags (least-privilege; default production posture) ----
# Read-only discovery/history are safe to enable when OAuth permits.
ENABLE_SOURCE_DISCOVERY=true
ENABLE_SOURCE_HISTORY=true
ENABLE_SOURCE_CREATION=true
# Support-only & destructive capabilities default OFF.
ENABLE_ORG_SYNC_DIAGNOSTICS=false
ENABLE_FULL_SYNC=false
ENABLE_PROXY_UPLOAD=false
ENABLE_SOURCE_UPDATE=false
ENABLE_SOURCE_DELETE=false

# ---- Upload / limits (optional; sensible defaults applied if unset) ----
# Warn (do not block) when a single file exceeds this many MB.
MAX_FILE_WARN_MB=50
# Hard cap on number of files selected per sync round.
MAX_SELECTED_FILES=500
# Max bytes the streaming proxy fallback will relay per file (only used when
# ENABLE_PROXY_UPLOAD=true). Keep aligned with your Vercel plan's limits.
PROXY_UPLOAD_MAX_BYTES=26214400
# Seconds the workflow waits for a browser upload result before pausing as
# NeedsUserAction (never as a false completion).
WORKFLOW_UPLOAD_WAIT_SECONDS=900

# ---- Content-Security-Policy: direct-upload connect-src allowlist ----
# Direct browser→Genesys upload requires the pre-signed URL host to be allowed
# by connect-src. Add a SPACE-separated list of HTTPS origins for your region's
# upload host(s), e.g. "https://*.s3.amazonaws.com https://*.pure.cloud".
# Leave empty to force the same-origin proxy fallback (ENABLE_PROXY_UPLOAD=true).
GENESYS_UPLOAD_CONNECT_SRC=
